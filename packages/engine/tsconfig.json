{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "../ghosthands/src"],
  "exclude": [
    "node_modules",
    "dist",
    "../ghosthands/src/__tests__/**",
    "../ghosthands/src/scripts/**",
    "../ghosthands/__tests__/**"
  ]
}
