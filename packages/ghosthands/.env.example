# GhostHands Environment Configuration
# Copy to .env and fill in your values

# --- Supabase Database ---
DATABASE_URL="postgresql://..."
DATABASE_DIRECT_URL="postgresql://..."
SUPABASE_DIRECT_URL="postgresql://..."
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SECRET_KEY="your-secret-key"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
# Legacy names (still accepted as fallbacks):
# SUPABASE_SERVICE_KEY, SUPABASE_ANON_KEY

# --- LLM Model Selection ---
# Which model to use by default. Aliases: deepseek-chat, qwen-72b, glm-5, gpt-4o, etc.
# See src/config/models.config.json for all options and presets.
GH_MODEL=deepseek-chat

# --- LLM Provider API Keys ---
# Only set keys for providers you plan to use.

# DeepSeek (text-only, cheap reasoning)
DEEPSEEK_API_KEY=

# SiliconFlow (Qwen vision models, cheapest)
SILICONFLOW_API_KEY=

# Zhipu AI (GLM-5 vision model)
ZHIPU_API_KEY=

# OpenAI (GPT-4o, expensive)
OPENAI_API_KEY=

# Anthropic (Claude, premium tier only)
ANTHROPIC_API_KEY=

# Google AI (Gemini, fallback)
GOOGLE_API_KEY=

# Moonshot / Kimi (optional)
MOONSHOT_API_KEY=

# MiniMax (optional)
MINIMAX_API_KEY=

# --- Storage (shared with VALET) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET_RESUMES=resumes
S3_BUCKET_SCREENSHOTS=screenshots
S3_BUCKET_ARTIFACTS=artifacts

# --- Testing ---
# Supabase user UUID used by test scripts (apply-workday, submit-test-job, etc.)
# Set this to YOUR user ID so session injection loads the right cookies.
GH_TEST_USER_ID=00000000-0000-0000-0000-000000000001

# --- GhostHands Specific ---
GHOSTHANDS_TABLE_PREFIX=gh_
GH_SERVICE_SECRET="change-in-production"

# --- Gmail Verification Automation (operator-owned OAuth app, per-user inbox) ---
GH_EMAIL_AUTOMATION_ENABLED=true
GH_EMAIL_PROVIDER=gmail_api
GH_GOOGLE_OAUTH_CLIENT_ID=
GH_GOOGLE_OAUTH_CLIENT_SECRET=
GH_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3100/api/v1/gh/oauth/google/callback
# Optional dedicated state-signing secret (falls back to GH_GOOGLE_OAUTH_CLIENT_SECRET)
GH_GOOGLE_OAUTH_STATE_SECRET=
# Hex-encoded 32-byte key used to encrypt per-user Gmail tokens at rest
GH_EMAIL_TOKEN_ENCRYPTION_KEY=
GH_EMAIL_TOKEN_ENCRYPTION_KEY_ID=1
GH_GMAIL_VERIFICATION_TIMEOUT_SECONDS=120
GH_GMAIL_VERIFICATION_POLL_SECONDS=5
GH_GMAIL_VERIFICATION_LOOKBACK_MINUTES=15
